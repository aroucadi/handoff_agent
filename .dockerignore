# Synapse .dockerignore

# Exclude source frontend (main app)
/frontend/

# Exclude node_modules everywhere
**/node_modules/

# Exclude crm source but allow its dist
crm-simulator/frontend/src/
crm-simulator/frontend/node_modules/
crm-simulator/frontend/public/
crm-simulator/frontend/*.ts
crm-simulator/frontend/*.json

# Keep these
!crm-simulator/frontend/dist/

.git/
video/
infra/
scripts/
skill-graphs/
__pycache__
*.pyc
.env
.DS_Store
