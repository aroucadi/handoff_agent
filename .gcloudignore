# Synapse — Google Cloud Build Ignore File
# This file overrides .gitignore for `gcloud builds submit` to ensure
# pre-built frontend dist/ directories are included in the build context.

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
*.egg
venv/
.venv/
env/

# Node.js (exclude node_modules but NOT dist/)
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files
.env
.env.local
.env.production
*.tfvars
!terraform.tfvars.example

# Terraform (state files, not config)
**/.terraform/
*.tfstate
*.tfstate.backup
.terraform.lock.hcl

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Secrets
*.key
*.pem
credentials.json
service-account.json

# Git
.git/

# Agents/Brain (development-only)
.agents/
.gemini/

# Temp files
temp_contracts/
crm-simulator/uploads/
